# 企微智能机器人（企业微信管理后台创建）
WECOM_BOT_ID=your-bot-id
WECOM_BOT_SECRET=your-bot-secret
# 目标群 chatid（Spike 0：从首条群消息日志中获取，或后台配置）
WECOM_CHAT_ID=

# SQLite 数据库路径（默认 ./data/bot.db）
DB_PATH=./data/bot.db

# LLM（OpenAI 兼容 API）；留空则使用规则模板总结（便于本地测试）
LLM_API_BASE=https://api.deepseek.com
LLM_API_KEY=your-deepseek-key
LLM_MODEL=deepseek-chat

# 时区与保留
CRON_TZ=Asia/Shanghai
MSG_RETENTION_DAYS=7

# 日志级别 debug | info | warn | error
LOG_LEVEL=info

LARK_BOT_OPEN_ID=ou_941655deb2a34d2bf5e49c69b625c20d
# lark-cli 扁平事件无 mentions 时，用机器人在群里显示的 @ 名（与 open_id 不同）
LARK_BOT_MENTION_NAMES=zdltest01
